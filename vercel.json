{
  "version": 2,
  "builds": [
    {
      "src": "api/products/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/pricing/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/products(.*)",
      "dest": "/api/products/index.py"
    },
    {
      "src": "/api/pricing(.*)",
      "dest": "/api/pricing/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ]
}